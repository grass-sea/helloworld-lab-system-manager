generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  fullName     String
  email        String        @unique
  password     String
  role         Role
  createdAt    DateTime      @default(now())
  borrowOrders BorrowOrder[]
}

model Item {
  id            Int            @id @default(autoincrement())
  name          String
  categoryId    Int
  type          ItemType
  location      String
  createdAt     DateTime       @default(now())
  borrowDetails BorrowDetail[]
  category      Category       @relation(fields: [categoryId], references: [id])
  stock         Stock?
}

model Stock {
  id           Int  @id @default(autoincrement())
  itemId       Int  @unique
  quantity     Int
  minimumLevel Int
  item         Item @relation(fields: [itemId], references: [id])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  items     Item[]
}

model BorrowOrder {
  id         Int            @id @default(autoincrement())
  userId     Int
  status     BorrowStatus   @default(PENDING)
  borrowDate DateTime?
  returnDate DateTime?
  createdAt  DateTime       @default(now())
  details    BorrowDetail[]
  user       User           @relation(fields: [userId], references: [id])
}

model BorrowDetail {
  id            Int         @id @default(autoincrement())
  borrowOrderId Int
  itemId        Int
  quantity      Int
  borrowOrder   BorrowOrder @relation(fields: [borrowOrderId], references: [id])
  item          Item        @relation(fields: [itemId], references: [id])
}

enum Role {
  ADMIN
  LECTURER
  STUDENT
}

enum ItemType {
  CONSUMABLE
  FIXED
}

enum BorrowStatus {
  PENDING
  APPROVED
  REJECTED
  BORROWED
  RETURNED
}
